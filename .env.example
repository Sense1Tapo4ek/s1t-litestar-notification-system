# ── General ──────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Core context ──────────────────────────────────────────────
# SQLite database path
CORE_DB_URL=sqlite+aiosqlite:///storage/app.sqlite

# ── Notifications context ─────────────────────────────────────
# Telegram Bot API request timeout in seconds
NOTIFICATIONS_API_TIMEOUT_SECONDS=10

# Override Telegram API base URL (e.g. for local Bot API Server)
# NOTIFICATIONS_TELEGRAM_API_URL=https://api.telegram.org

# ── Optional ──────────────────────────────────────────────────
# Host port exposed by docker-compose (default: 8000)
# PORT=8000
